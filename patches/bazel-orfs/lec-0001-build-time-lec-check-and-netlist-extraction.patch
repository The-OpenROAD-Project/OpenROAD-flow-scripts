+# Writes a LEC-comparable Verilog netlist for an ORFS stage .odb.
+#
+# For use with bazel-orfs orfs_run(src = <stage>, script = this,
+# outs = ["results/<pdk>/<top>/<variant>/<stem>_lec.v"]): open.tcl
+# reads $::env(ODB_FILE) (honouring OPENROAD_HIERARCHICAL via
+# hier_options), liberty is read so physical-only master detection can
+# tell filler/tap/decap cells from logic, and the netlist is written
+# with those masters removed so kepler-formal only sees logic.
+source $::env(SCRIPTS_DIR)/util.tcl
+source $::env(SCRIPTS_DIR)/read_liberty.tcl
+source $::env(SCRIPTS_DIR)/open.tcl
+
+set stem [file rootname [file tail $::env(ODB_FILE)]]
+write_verilog -remove_cells [find_physical_only_masters] \
+  $::env(RESULTS_DIR)/${stem}_lec.v
