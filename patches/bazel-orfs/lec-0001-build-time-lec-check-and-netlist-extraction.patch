 """Rules for kepler-formal LEC (Logic Equivalence Checking).
 
-Generates a config file from template, runs kepler-formal, and
-reports pass/fail as a Bazel test.
+Two usage styles:
 
-kepler-formal operates on Verilog netlists and checks combinational
-equivalence. Sequential boundary changes are not supported.
+1. `lec_test`: runs kepler-formal at test time. Simple, but the
+   (potentially very long) SAT run re-executes whenever the test
+   re-runs and is subject to test timeouts.
 
-Requirements for the input Verilog:
+2. `lec(name, ...)` macro: emits a build-time `lec_check` action that
+   runs kepler-formal during `bazel build`, records the verdict in
+   `<name>.status` (plus the full log), and a `<name>_test`
+   `lec_status_test` that only asserts the recorded verdict. The
+   expensive work caches like any other build artifact and the test is
+   instant, so wide `bazel test` sweeps do not time out.
+
+kepler-formal operates on Verilog netlists. The default `lec`
+verification checks combinational equivalence:
   - No change of sequential boundaries between gold and gate.
   - No change in names of hierarchical instances, sequential instances,
     and top terminals.
+`verification = "sec"` selects sequential equivalence checking, which
+also accepts pre-synthesis (RTL) Verilog for gold, compared against a
+gate netlist (RTL-vs-gate).
 """
 
+LecInfo = provider(
+    "Recorded verdict of a build-time kepler-formal run.",
+    fields = {
+        "status": "File: one-line PASS/FAIL verdict",
+        "log": "File: full kepler-formal stdout/stderr",
+        "miter_log": "File: kepler-formal miter log (YAML log_file)",
+    },
+)
+
+def _lec_config(ctx, miter_log):
+    """Build the kepler-formal YAML config content."""
+    lines = ["format: " + ctx.attr.format]
+    if ctx.attr.verification != "lec":
+        lines.append("verification: " + ctx.attr.verification)
+    lines.append("input_paths:")
+    lines.append(
+        "  - [" + ", ".join([f.path for f in ctx.files.gold_verilog_files]) + "]",
+    )
+    lines.append(
+        "  - [" + ", ".join([f.path for f in ctx.files.gate_verilog_files]) + "]",
+    )
+    if ctx.files.liberty_files:
+        lines.append("liberty_files:")
+        lines += ["  - " + f.path for f in ctx.files.liberty_files]
+    lines.append("log_level: " + ctx.attr.log_level)
+    lines.append("log_file: " + miter_log.path)
+    lines += ctx.attr.extra_config
+    return "\n".join(lines) + "\n"
+
+def _lec_check_impl(ctx):
+    config = ctx.actions.declare_file(ctx.attr.name + ".yaml")
+    log = ctx.actions.declare_file(ctx.attr.name + ".log")
+    miter_log = ctx.actions.declare_file(ctx.attr.name + ".miter.log")
+    status = ctx.actions.declare_file(ctx.attr.name + ".status")
+
+    ctx.actions.write(config, _lec_config(ctx, miter_log))
+
+    # The action itself always succeeds: the kepler-formal verdict
+    # (exit code, or "Found difference" in the logs) is captured in the
+    # .status file so that failures are cached build artifacts asserted
+    # by lec_status_test, not build errors.
+    ctx.actions.run_shell(
+        command = """
+set -u
+rc=0
+"$1" --config "$2" > "$3" 2>&1 || rc=$?
+touch "$4"
+# SEC reports checked-output coverage; a PASS that skipped most
+# outputs is much weaker than a full proof, so record it next to the
+# verdict.
+cov="$(grep -o "checked-output coverage: [0-9.]*% ([0-9/]* covered/existing outputs)" "$3" | tail -n 1)"
+if [ "$rc" -eq 0 ] && ! grep -q "Found difference" "$3" "$4"; then
+  echo "PASS${cov:+ ($cov)}" > "$5"
+else
+  echo "FAIL (kepler-formal exit=$rc)${cov:+ ($cov)}" > "$5"
+fi
+""",
+        arguments = [
+            ctx.executable._kepler_formal.path,
+            config.path,
+            log.path,
+            miter_log.path,
+            status.path,
+        ],
+        inputs = depset(
+            [config] +
+            ctx.files.gold_verilog_files +
+            ctx.files.gate_verilog_files +
+            ctx.files.liberty_files,
+        ),
+        outputs = [log, miter_log, status],
+        tools = [ctx.attr._kepler_formal[DefaultInfo].files_to_run],
+        mnemonic = "KeplerFormal",
+        progress_message = "LEC (kepler-formal) %{label}",
+    )
+
+    return [
+        DefaultInfo(files = depset([status, log, miter_log, config])),
+        LecInfo(status = status, log = log, miter_log = miter_log),
+    ]
+
+_LEC_IO_ATTRS = {
+    "gold_verilog_files": attr.label_list(
+        doc = "Gold (reference) Verilog files.",
+        allow_files = True,
+        providers = [DefaultInfo],
+    ),
+    "gate_verilog_files": attr.label_list(
+        doc = "Gate (modified) Verilog files.",
+        allow_files = True,
+        providers = [DefaultInfo],
+    ),
+    "liberty_files": attr.label_list(
+        doc = "Liberty (.lib) files for cell definitions. Optional for RTL-to-RTL checks.",
+        allow_files = True,
+        providers = [DefaultInfo],
+        default = [],
+    ),
+    "log_level": attr.string(
+        doc = "Log verbosity: debug, info, warning, error.",
+        default = "info",
+    ),
+    "_kepler_formal": attr.label(
+        doc = "kepler-formal binary.",
+        executable = True,
+        allow_files = True,
+        cfg = "exec",
+        default = Label("@kepler-formal//src/bin:kepler-formal"),
+    ),
+}
+
+lec_check = rule(
+    implementation = _lec_check_impl,
+    doc = """Build-time logic equivalence check using kepler-formal.
+
+    Runs kepler-formal as a (cacheable) build action and records the
+    verdict in `<name>.status` alongside the full log. Pair with
+    lec_status_test (or use the lec() macro) to surface the verdict as
+    a test.
+    """,
+    attrs = _LEC_IO_ATTRS | {
+        "verification": attr.string(
+            doc = "Verification mode: lec (combinational) or sec (sequential; accepts RTL gold).",
+            default = "lec",
+            values = ["lec", "sec"],
+        ),
+        "format": attr.string(
+            doc = "Input format: verilog (netlist parser both sides), sv2v (gold through " +
+                  "the SystemVerilog frontend, gate as Verilog netlist; required for " +
+                  "behavioral/pre-synthesis gold and implies sec), or systemverilog.",
+            default = "verilog",
+            values = ["verilog", "sv2v", "systemverilog"],
+        ),
+        "extra_config": attr.string_list(
+            doc = "Extra raw YAML config lines appended to the generated kepler-formal " +
+                  "config (e.g. 'sec_engine: pdr', 'solver: kissat').",
+            default = [],
+        ),
+    },
+)
+
+def _lec_status_test_impl(ctx):
+    info = ctx.attr.check[LecInfo]
+    script = ctx.actions.declare_file(ctx.attr.name + ".sh")
+    ctx.actions.write(
+        script,
+        """#!/bin/sh
+status="$(cat "{status}")"
+echo "{check}: $status"
+case "$status" in
+PASS*)
+  exit 0
+  ;;
+esac
+echo "--- kepler-formal log (last 200 lines) ---"
+tail -n 200 "{log}"
+exit 1
+""".format(
+            check = str(ctx.attr.check.label),
+            status = info.status.short_path,
+            log = info.log.short_path,
+        ),
+        is_executable = True,
+    )
+    return [
+        DefaultInfo(
+            executable = script,
+            runfiles = ctx.runfiles(files = [info.status, info.log]),
+        ),
+    ]
+
+lec_status_test = rule(
+    implementation = _lec_status_test_impl,
+    doc = """Asserts that a lec_check recorded PASS.
+
+    Instant: only reads the verdict recorded at build time, so LEC
+    results stay cached and wide test sweeps cannot time out on SAT
+    runtimes.
+    """,
+    attrs = {
+        "check": attr.label(
+            doc = "The lec_check whose verdict to assert.",
+            mandatory = True,
+            providers = [LecInfo],
+        ),
+    },
+    test = True,
+)
+
+def lec(name, tags = [], visibility = None, **kwargs):
+    """Build-time LEC with an instant verdict test.
+
+    Emits `<name>` (lec_check build target running kepler-formal) and
+    `<name>_test` (lec_status_test asserting the recorded verdict).
+
+    Args:
+        name: base name for the check/test pair.
+        tags: applied to both targets.
+        visibility: applied to both targets.
+        **kwargs: forwarded to lec_check (gold_verilog_files,
+            gate_verilog_files, liberty_files, verification,
+            extra_config, log_level).
+    """
+    lec_check(
+        name = name,
+        tags = tags,
+        visibility = visibility,
+        **kwargs
+    )
+    lec_status_test(
+        name = name + "_test",
+        check = ":" + name,
+        tags = tags,
+        visibility = visibility,
+    )
+
 def _lec_test_impl(ctx):
     # Generate kepler-formal YAML config
     config = ctx.actions.declare_file(ctx.attr.name + ".yaml")
