+"""lec module self-tests.
+
+Run from the lec module root (`cd lec && bazelisk test //test/...`).
+With no kepler-formal override in play these exercise the rule wiring
+against the CI mock (../mock/kepler-formal), which always reports
+equivalence; point the kepler-formal module at a real checkout to turn
+them into true LEC runs.
+"""
+
+load("//:lec.bzl", "lec", "lec_test")
+
+# Test-time rule: kepler-formal runs inside the test action.
+lec_test(
+    name = "fixture_runtime_lec_test",
+    gate_verilog_files = ["gate.v"],
+    gold_verilog_files = ["gold.v"],
+)
+
+# Build-time check + instant verdict test pairs:
+# fixture_lec/_test and fixture_sec/_test.
+lec(
+    name = "fixture_lec",
+    gate_verilog_files = ["gate.v"],
+    gold_verilog_files = ["gold.v"],
+)
+
+lec(
+    name = "fixture_sec",
+    extra_config = ["sec_engine: pdr"],
+    gate_verilog_files = ["gate.v"],
+    gold_verilog_files = ["gold.v"],
+    verification = "sec",
+)
